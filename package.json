{
  "name": "ngx-dashboard",
  "version": "0.0.0",
  "engines": {
    "node": ">=24.15.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node scripts/generate-versions.js",
    "build": "ng build ngx-dashboard && ng build ngx-dashboard-widgets && ng build demo",
    "prebuild:ci": "node scripts/generate-versions.js",
    "build:ci": "ng build ngx-dashboard && ng build ngx-dashboard-widgets && ng build demo",
    "prebuild:ngx-dashboard": "node scripts/generate-versions.js",
    "build:ngx-dashboard": "ng build ngx-dashboard",
    "prebuild:ngx-dashboard-widgets": "node scripts/generate-versions.js",
    "build:ngx-dashboard-widgets": "ng build ngx-dashboard-widgets",
    "build:demo": "ng build demo",
    "watch": "ng build --watch --configuration development",
    "test": "ng test ngx-dashboard --no-watch --browsers=ChromeHeadless && ng test ngx-dashboard-widgets --no-watch --browsers=ChromeHeadless && ng test demo --no-watch --browsers=ChromeHeadless",
    "test:ci": "ng test --no-watch --browsers=ChromeHeadless --code-coverage",
    "lint": "ng lint demo && ng lint ngx-dashboard && ng lint ngx-dashboard-widgets",
    "i18n:extract": "ng extract-i18n demo",
    "i18n:update": "ng extract-i18n demo",
    "extract-i18n": "ng extract-i18n demo",
    "build:i18n": "ng build demo --configuration=production-all",
    "build:i18n:es": "ng build demo --configuration=production-es",
    "build:i18n:fr": "ng build demo --configuration=production-fr",
    "build:i18n:de": "ng build demo --configuration=production-de",
    "serve:es": "ng serve demo --configuration=es",
    "serve:fr": "ng serve demo --configuration=fr",
    "serve:de": "ng serve demo --configuration=de"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "//overrides": "TEMPORARY @ngrx/signals shim: held at 21.x under Angular 22 because no @ngrx/signals v22 had shipped (its peer pins @angular/core ^21). The @ngrx/signals override below redirects that peer to the root Angular version so install resolves without --legacy-peer-deps. WHEN UPGRADING NGRX to an Angular-22-compatible release: bump @ngrx/signals and DELETE its overrides entry. See NgRx issue #5158.",
  "overrides": {
    "vite": "^7.3.2",
    "esbuild": "^0.28.1",
    "@angular/build": {
      "undici": "^7.28.0"
    },
    "@ngrx/signals": {
      "@angular/common": "$@angular/common",
      "@angular/core": "$@angular/core"
    }
  },
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.4",
    "@angular/compiler": "^22.0.4",
    "@angular/core": "^22.0.4",
    "@angular/forms": "^22.0.4",
    "@angular/localize": "^22.0.4",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.4",
    "@angular/platform-browser-dynamic": "^22.0.4",
    "@angular/router": "^22.0.4",
    "@ngrx/signals": "^21.0.1",
    "rxjs": "~7.8.0",
    "rxjs-interop": "^2.0.0",
    "sparklib": "^1.1.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.4",
    "@types/jasmine": "~5.1.9",
    "angular-eslint": "22.0.0",
    "eslint": "^9.33.0",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "ng-extract-i18n-merge": "^3.4.0",
    "ng-packagr": "^22.0.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.62.0",
    "zone.js": "^0.15.0"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "*",
    "@esbuild/win32-x64": "*"
  }
}